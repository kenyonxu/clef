openspec/

# Server (removed from release, tombstoned)
server/

# Secrets
docs/secrets/

# Clef work files (intermediate)
.clef-work/

# Clef output: only track root .mid files, ignore everything else
addons/clef/output/*
!addons/clef/output/*.mid
!addons/clef/output/*.mid.import

# SF2 bundles: keep profile JSONs only, ignore large binary bundles
addons/clef/sound_front/*
!addons/clef/sound_front/*.json

# Claude Code (exclude everything except clef-compose content)
.claude/*
!.claude/agents/clef-*
!.claude/skills/
.claude/skills/*
!.claude/skills/clef-compose/
!.claude/skills/clef-iterate/
!.claude/skills/theory-*/
!.claude/skills/theory-reference.md
!.claude/requirements.txt
!.claude/setup.bat
!.claude/setup.sh
!.claude/settings.json
!.claude/hooks/*.py
# Re-ignore user-specific and local files
.claude/settings.local.json
.claude/worktrees/
.claude/.venv/

# Python dependencies (vendored)
music21/
pytest-of-kenyo/

# Server config with real API keys
server/config/providers.yaml
server/start-server.bat
server/start.bat

# Frontend build output
server/web/dist/
server/web/node_modules/

# Graphify build artifacts (track graph.json, GRAPH_REPORT.md, manifest.json, cost.json)
graphify-out/cache/
graphify-out/.graphify_*
.graphify_python
.graphify_detect.json
.graphify_extract.json
