{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "()": "uvicorn.logging.DefaultFormatter",
      "fmt": "%(levelprefix)s %(message)s",
      "use_colors": null
    },
    "access": {
      "()": "uvicorn.logging.AccessFormatter",
      "fmt": "%(levelprefix)s %(client_addr)s - \"%(request_line)s\" %(status_code)s"
    },
    "app": {
      "fmt": "%(asctime)s %(levelname)-8s %(name)s | %(message)s",
      "datefmt": "%H:%M:%S"
    }
  },
  "handlers": {
    "default": {
      "formatter": "default",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    },
    "access": {
      "formatter": "access",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    },
    "app": {
      "formatter": "app",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn.error": {
      "level": "INFO",
      "handlers": ["default"],
      "propagate": true
    },
    "uvicorn.access": {
      "handlers": ["access"],
      "propagate": false
    },
    "": {
      "handlers": ["default"],
      "level": "INFO",
      "propagate": true
    },
    "clef_server": {
      "handlers": ["app"],
      "level": "INFO",
      "propagate": false
    },
    "agent_framework": {
      "handlers": ["app"],
      "level": "INFO",
      "propagate": false
    }
  }
}
