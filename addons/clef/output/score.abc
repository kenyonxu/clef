%%MIDI channel 0
%%MIDI program 40
V:1
% VOICE: melody
% === A段: 晨曦苏醒 (m1-8) ===
% energy=3, intimate, sparse, violin legato
% 动机: 纯五度上跳后级进下行 (Celtic folk motif: d'-g'-e')
% 和弦进行: G(I) - C(IV) - Am(vi) - D(V) | Em(iii) - C(IV) - Dsus4-D(V) - G(I)
% 音高丰富度优化: 增加e'/d'/c'/^f'/f'使用，降低g'/a'/b'集中度
!mf! (d'2 g'4 e'2) | (e'4 d'2 c'2) | (e'2 ^f'4 g'2) | (^f'2 e'2 d'2 e'2) |
(e'2 c'2 d'2 c'2) | (e'2 c'4 d'2) | (d'2 c'2 e'2 ^f'2) | (b'2 a'2 g'4) |
% === B段: 城镇渐活 (m9-16) ===
% energy=5, melody_forward, normal density, mf
% melody_strategy: variation — A段五度动机(g'-c'')节奏加密+音区上移
% 和弦进行: C(IV) - G/B(I) - Am(vi) - D(V) | G(I) - D(V) - C(IV) - G(I)
% 变化音: m12 _b'(Bb5) 半音经过音增加现代感
(g' f' c''2 b'2 a'2) | (b' d'' b'2 a'2 ^f'2) | (a'2 c'' b' a'2 g'2) | (d''2 c''2 _b' a' ^f'2) |
!f! (b'2 c'' d'' b'2 g'2) | (d''2 c''2 b'2 a'2) | !mf! (g'2 f'2 e'2 d'2) | (g'2 e'2 d'4) |
%%MIDI channel 1
%%MIDI program 24
V:2
% VOICE: harmony
% === A段: 晨曦苏醒 (m1-8) ===
% energy=3, intimate, sparse, nylon guitar arpeggiated texture
% 和弦进行: G(I) - C(IV) - Am(vi) - D(V) | Em(iii) - C(IV) - Dsus4-D(V) - G(I)
% 凯尔特特征: m7 使用 sus4 挂留音; 分解和弦与柱式交替
!mp! "G" [B,dg]2 z2 [B,dg]4 | "C" [ceg]6 z2 | "Am" [cea]4 z4 | "D" [D^Fa]2 z2 [D^Fa]4 |
"Em" [B,eg]4 z4 | "C" [ceg]2 [ceg]2 z4 | "Dsus4" [DgA]4 "D" [D^FA]4 | "G" [B,dg]8 |
% === B段: 城镇渐活 (m9-16) ===
% energy=5, melody_forward, normal density, mf
% 和弦进行: C(IV) - G/B(I) - Am(vi) - D(V) | G(I) - D(V) - C(IV) - G(I)
% 八分分解和弦更密节奏，m15-16 正格终止过渡回 A 段
!mf! "C" [ceg]2 [ceg]2 [ceg]2 [ceg]2 | "G" [B,dg]2 [B,dg]2 [B,dg]2 [B,dg]2 | "Am" [cea]2 [cea]2 [ceg]2 [ceg]2 | "D" [D^Fa]2 [D^Fa]2 [D^Fa]2 [D^Fa]2 |
"G" [dgB]2 [dgB]2 [dgB]2 [dgB]2 | "D" [D^Fa]2 [D^Fa]2 [D^Fa]2 [D^Fa]2 | "C" [ceg]2 [ceg]2 [ceg]2 [ceg]2 | "G" [B,dg]2 [B,dg]2 [B,dg]4 |
