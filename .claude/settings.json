{
  "permissions": {
    "allow": [
      "Edit(/.claude/skills/clef-compose/**)",
      "Edit(/.claude/skills/theory-*/**)",
      "Bash(python -m uvicorn clef_server.app:create_app --factory *)",
      "Bash(python -m uvicorn clef_server.app:app *)",
      "Bash(cmd.exe /c start_api_server.bat)",
      "Bash(PYTHONPATH=src python -m pytest *)",
      "Bash(.venv/Scripts/python.exe -m pytest *)",
      "Bash(.venv/Scripts/python.exe scripts/*)",
      "Bash(python -X utf8 scripts/*)",
      "Bash(python3 .claude/skills/clef-compose/scripts/*)",
      "Bash(curl -s http://localhost:8000/*)",
      "Bash(curl -s http://localhost:8900/*)",
      "Bash(curl -s -X POST http://localhost:8000/*)",
      "Bash(curl -s -X POST http://localhost:8900/*)",
      "Bash(curl -s -o /dev/null *)",
      "Bash(python -c \"from clef_server.*)",
      "Bash(node e:/GitHub/clef-dev/.understand-anything/tmp/*)",
      "Bash(pnpm --filter @understand-anything/core *)",
      "Bash(GRAPH_DIR=\"e:/GitHub/clef-dev\" npx vite *)",
      "Read(//e/GitHub/clef-dev/**)",
      "Bash(pip install *)",
      "mcp__zai-mcp-server__analyze_image"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log_agent_call.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}
