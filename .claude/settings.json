{
  "permissions": {
    "allow": [
      "Edit(/.claude/skills/clef-compose/**)",
      "Edit(/.claude/skills/theory-*/**)",
      "Bash(python* -m uvicorn *)",
      "Bash(python* -m pytest *)",
      "Bash(PYTHONPATH=* python* -m pytest *)",
      "Bash(.venv/*/python* *)",
      "Bash(python* scripts/*)",
      "Bash(python* .claude/skills/clef-compose/scripts/*)",
      "Bash(curl -s *)",
      "Bash(python* -c \"from clef_server.*)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(cmd.exe *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(pip install *)",
      "Read(**)",
      "mcp__zai-mcp-server__analyze_image"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log_agent_call.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}
